{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "app/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/task/(.*)",
      "dest": "app/index.js"
    },
    {
      "src": "/((?!assets/).*)",
      "dest": "/index.html"
    }
  ]
}